#include <stdio.h>

int factorial(int n) {
    // Base Case: factorial of 0 or 1 is 1
    if (n <= 1) {
        return 1;
    }
    // Recursive Step: n * factorial of (n-1)
    return n * factorial(n - 1);
}

int main() {
    int num = 5;
    printf("Factorial of %d is %d\n", num, factorial(num));
    return 0;
}
